LAMS = [ 0.15, 0.2]#, 1.0]
LAMS_MARKER_GENES = [0.1] #0.1
PALAVA_WIDTH = [ 25]
LIST_OF_NONLIN_FACTORS = [ '0-1-2-16-21','none'] # 'none', 'all', cannot put commas in widlcard bug in snakemake
STR_AB_EXP = ['ipsc_saved_models_paper']
SEEDS = [0,1,2,3,4]
rule all:
    input:
      #  expand('Out_files_and_results/{str_ab_exp}/seed={seed}_lambda={lam}_lambda_marker_genes={lambda_marker_genes}_palava_width={palava_width}_list_of_nonlin_factors={list_of_nonlin_factors}/done.txt',
