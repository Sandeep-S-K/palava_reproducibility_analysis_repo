         expand('Out_files_and_results_cc/{str_ab_exp}/seed={seed}_lambda={lam}_lambda_marker_genes={lambda_marker_genes}_palava_width={palava_width}_list_of_nonlin_factors={list_of_nonlin_factors}/done.txt',
               lam=LAMS,
               palava_width=PALAVA_WIDTH,
             list_of_nonlin_factors=LIST_OF_NONLIN_FACTORS,
               str_ab_exp=STR_AB_EXP,
                     lambda_marker_genes =LAMS_MARKER_GENES,
                seed = SEEDS
             )
         #'intermediate_results/spectra_results_iPSC_with_pathways_cell_metadata_and_stages.npy'


rule run_palava_cc:
    output:
        'Out_files_and_results_cc/{str_ab_exp}/seed={seed}_lambda={lam}_lambda_marker_genes={lambda_marker_genes}_palava_width={palava_width}_list_of_nonlin_factors={list_of_nonlin_factors}/done.txt'
    resources:
        runtime=650,
        mem_mb=150000,
        cpus=1,
        gres='gpu:1',
        account='punim0614',
        partition='fos-gpu-l40s',
        output_dr= lambda wildcards: f"Out_files_and_results_cc/{wildcards.str_ab_exp}/seed={wildcards.seed}_lambda={wildcards.lam}_lambda_marker_genes={wildcards.lambda_marker_genes}_palava_width={wildcards.palava_width}_list_of_nonlin_factors={wildcards.list_of_nonlin_factors}/run_palava_%x.%j.out",
        job_name= 'scvi_palava'
    conda:
        "palava-new2-env"
    shell:
        """
        python scVI_palava_ipsc-cc.py --lambda_='{wildcards.lam}' --str_ab_exp='{wildcards.str_ab_exp}' --palava_width='{wildcards.palava_width}' --list_of_nonlin_factors='{wildcards.list_of_nonlin_factors}' --lambda_marker_genes='{wildcards.lambda_marker_genes}' --seed='{wildcards.seed}' --dir='seed={wildcards.seed}_lambda={wildcards.lam}_lambda_marker_genes={wildcards.lambda_marker_genes}_palava_width={wildcards.palava_width}_list_of_nonlin_factors={wildcards.list_of_nonlin_factors}'
        """
