rule add_gene_sets_adata_excessive:
    input:
        "data/sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle.h5ad"
    output:
        "data/sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_MS_{ms}_EX_{ex}.h5ad"
    resources:
        runtime= 20,
        mem_mb= 10000,
        cpus= 1,
        gres = 'gpu:0',
        account = 'punim0614',
        partition = 'cascade,sapphire',
        output_dr = 'Out_files/%x.%j.out',
        job_name = 'adding_gen_sets_adata'
    conda:
       "palava-new2-env"
    params:
       data_dr = "data/sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle.h5ad",
       MS = '{ms}',
       EX = '{ex}'
    shell:
        """
        python add_gene_sets_adata_excessive.py --data_directory='{params.data_dr}' --MS={params.MS} --EX={params.EX}
        """


