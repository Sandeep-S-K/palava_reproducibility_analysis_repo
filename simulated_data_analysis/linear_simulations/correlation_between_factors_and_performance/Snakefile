ERRORS_ = expand('MS_{i}_EX_0', i = [ 0, 50])
ERRORS_ += expand('MS_0_EX_{i}', i = [ 50]) 

SEEDS = [10,11,12,13,14]#,3,4,5,6,7,8,9] 

PERCENT_ACT_SHUFFLE = [100, 26, 10, 5, 2, 0 ] # corresponds to corr [0.7,0.8,0.9, 0.95]

spectra_results =  expand('intermediate_results/spectra_results_sim_anndata_linear_model_5000_cells_2000_genes_4_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{errors_}.npy', seed=SEEDS, errors_ =ERRORS_,percent_act_shuffle= PERCENT_ACT_SHUFFLE)

adata =  expand('data/sim_anndata_linear_model_5000_cells_2000_genes_4_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{errors_}.h5ad', seed=SEEDS, errors_ =ERRORS_, percent_act_shuffle= PERCENT_ACT_SHUFFLE)


slalom_results =  expand('intermediate_results/slalom_results_sim_anndata_linear_model_5000_cells_2000_genes_4_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{errors_}.npy', seed=SEEDS, errors_ =ERRORS_,percent_act_shuffle= PERCENT_ACT_SHUFFLE)


palava_results =  expand('intermediate_results/palava_results_sim_anndata_linear_model_5000_cells_2000_genes_4_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{errors_}.npy', seed=SEEDS, errors_ =ERRORS_, percent_act_shuffle= PERCENT_ACT_SHUFFLE)

palava_linear_results =  expand('intermediate_results/linear_palava_results_sim_anndata_linear_model_5000_cells_2000_genes_4_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{errors_}.npy', seed=SEEDS, errors_ =ERRORS_,percent_act_shuffle= PERCENT_ACT_SHUFFLE)




rule all:
    input:
        palava_linear_results, 
        palava_results,
        spectra_results,
        slalom_results,
        adata
        #"data/sim_anndata_linear_model_5000_cells_2000_genes_4_factors_0_seed.h5ad"


rule run_spectra:
    input:
       "data/sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{error_str}.h5ad"
    output: 
        'intermediate_results/spectra_results_sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{error_str}.npy'
    resources:
        runtime= 500,
        mem_mb= 50000,
        cpus= 1,
        gres = 'gpu:0',
        account = 'punim0614',
        partition = 'cascade,sapphire',
        output_dr = 'Out_files/run_spectra_%x.%j.out',
        job_name = 'spectra'
    conda:
       "spectra-env-new"
    params:
       data_dr = "data/sim_anndata_linear_model_{cells}_cells_{genes}_genes_{factors}_factors_{seed}_seed_{percent_act_shuffle}_percent_act_shuffle_gene_sets_formatted_{error_str}.h5ad"

    shell:
        """
        python run_spectra.py --data_directory='{params.data_dr}'
        """



